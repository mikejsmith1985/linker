# ---- Database ----
# When running via docker compose this is set for you. For `make run` locally,
# point at a Postgres you control.
DATABASE_URL=postgres://linker:linker@localhost:5432/linker?sslmode=disable

# ---- Claude (required for real drafts) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- GitHub (read-only) ----
# A classic or fine-grained PAT with repo read access. Raises rate limits and
# lets linker see your private repos.
GITHUB_TOKEN=
# Comma-separated list of repos to watch, e.g. mikejsmith1985/linker,mikejsmith1985/foo
GITHUB_REPOS=

# ---- Buffer (optional) ----
# Leave BUFFER_ACCESS_TOKEN blank to run in stub mode: posts are "queued"
# locally and logged, with no external calls. Set both to publish to LinkedIn.
BUFFER_ACCESS_TOKEN=
BUFFER_PROFILE_ID=

# ---- Cadence / scheduling ----
POLL_INTERVAL=15m
POST_MIN_INTERVAL=24h

# ---- Web ----
HTTP_ADDR=:8080

# ---- Persona (optional override) ----
# Path to a markdown file that replaces the built-in LinkedIn voice prompt.
PERSONA_PROMPT_PATH=
