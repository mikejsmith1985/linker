# ---- Database ----
# When running via docker compose this is set for you. For `make run` locally,
# point at a Postgres you control.
DATABASE_URL=postgres://linker:linker@localhost:5432/linker?sslmode=disable

# ---- Claude (required for scoring + document generation) ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Adzuna (default job-search source) ----
# Free API credentials from https://developer.adzuna.com. Without these, the
# Adzuna source is skipped and reported as unavailable; you can still paste
# posting URLs to score them.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ---- Web ----
HTTP_ADDR=:8080
