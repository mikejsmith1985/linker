#!/usr/bin/env bash
# Forge Workflow Pre-Push Hook
# Generated by Forge Terminal Workflow Architect
# Runs build + test suite before allowing push. Ensures broken code never reaches remote.
# Bypass with: git push --no-verify

set +e
failures=()

echo -e "\033[36mRunning pre-push checks...\033[0m"

# ── Go Build + Test ─────────────────────────────────────────────────────
if [[ -f "go.mod" ]]; then
    echo -e "  \033[36m[Go] Building...\033[0m"
    build_output=$(go build ./cmd/forge/ 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("GO BUILD: go build ./cmd/forge/ failed")
        echo -e "  \033[31m[Go] Build FAILED\033[0m"
        echo "$build_output"
    else
        echo -e "  \033[32m[Go] Build passed\033[0m"
    fi

    echo -e "  \033[36m[Go] Testing...\033[0m"
    test_output=$(go test ./... 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("GO TEST: go test ./... failed")
        echo -e "  \033[31m[Go] Tests FAILED\033[0m"
        echo "$test_output"
    else
        echo -e "  \033[32m[Go] Tests passed\033[0m"
    fi
fi

# ── Frontend Build + Test ───────────────────────────────────────────────
if [[ -f "frontend/package.json" ]]; then
    echo -e "  \033[36m[Frontend] Testing...\033[0m"
    pushd frontend > /dev/null
    vitest_output=$(npx vitest run 2>&1)
    if [[ $? -ne 0 ]]; then
        failures+=("FRONTEND TEST: npx vitest run failed")
        echo -e "  \033[31m[Frontend] Tests FAILED\033[0m"
        echo "$vitest_output"
    else
        echo -e "  \033[32m[Frontend] Tests passed\033[0m"
    fi
    popd > /dev/null
fi

# ── Report ──────────────────────────────────────────────────────────────
if [[ ${#failures[@]} -gt 0 ]]; then
    echo -e "\n\033[31mPRE-PUSH FAILURES (blocking):\033[0m"
    for f in "${failures[@]}"; do echo -e "  \033[31m* $f\033[0m"; done
    echo -e "\033[31mPush blocked. Fix failures or use --no-verify to bypass.\033[0m"
    exit 1
fi

echo -e "\033[32mPre-push checks passed\033[0m"
exit 0
