#!/usr/bin/env bash
# Forge Workflow Commit-Msg Hook
# Generated by Forge Terminal Workflow Architect
# Validates commit message format: type: description
# Bypass with: git commit --no-verify

set +e
commit_msg_file="$1"
[[ -z "$commit_msg_file" || ! -f "$commit_msg_file" ]] && exit 0

# Extract the first non-comment, non-empty line as the subject
subject_line=$(grep -v '^#' "$commit_msg_file" | grep -v '^$' | head -n1 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
[[ -z "$subject_line" ]] && exit 0

# Allow merge commits and revert commits through without format check
if echo "$subject_line" | grep -qE '^(Merge |Revert )'; then
    exit 0
fi

# Validate format: type: description
valid_types="feat|fix|chore|docs|test|refactor|perf"
if ! echo "$subject_line" | grep -qE "^($valid_types): .+"; then
    echo -e "\n\033[31mCOMMIT-MSG VIOLATION:\033[0m"
    echo -e "  \033[31mMessage: '$subject_line'\033[0m"
    echo -e "  \033[31mExpected format: type: description\033[0m"
    echo -e "  \033[33mValid types: feat, fix, chore, docs, test, refactor, perf\033[0m"
    echo -e "  \033[32mExample: feat: add user authentication flow\033[0m"
    echo -e "\n\033[31mCommit blocked. Fix the message format or use --no-verify to bypass.\033[0m"
    exit 1
fi

# Check for Co-authored-by trailer (warning only, not blocking)
if ! grep -q 'Co-authored-by:' "$commit_msg_file"; then
    echo -e "\033[33mCOMMIT-MSG WARNING: Missing Co-authored-by trailer\033[0m"
fi

echo -e "\033[32mCommit message format valid\033[0m"
exit 0
